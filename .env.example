"""
环境变量配置模板

复制此文件为 .env 或通过命令行 export：
  Linux/Mac: source variables_local.env
  Windows:   复制为 variables_local.bat 并修改值
"""

# ========== 测试目标站点 ==========
export BASE_URL=<your_woocommerce_site_url>

# ========== 浏览器配置 ==========
# 可选值: chrome / headlesschrome / firefox / headlessfirefox / remote_chrome
export BROWSER=headlesschrome

# ========== 数据库配置（MySQL） ==========
export DB_HOST=<your_db_host>
export DB_PORT=<your_db_port>
export DB_DATABASE=<your_db_name>
export DB_TABLE_PREFIX=wp_
export DB_USER=<your_db_user>
export DB_PASSWORD=<your_db_password>

# ========== WooCommerce API 认证 ==========
export WOO_KEY=<your_consumer_key>
export WOO_SECRET=<your_consumer_secret>

# ========== 远程 WebDriver（仅 remote 模式需要） ==========
export REMOTE_WEBDRIVER=<your_selenium_grid_url>
